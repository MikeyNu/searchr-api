PORT=4000
DATA_DIR=./data
ALLOWED_ORIGINS=https://searchr.co.za,https://www.searchr.co.za,http://127.0.0.1:8082,http://localhost:8082,http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:8080,http://localhost:8080

# Official South African job aggregator source.
# Register at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_QUERIES=retail,admin,customer service,warehouse,learnership,internship,reception,driver,call centre
ADZUNA_LOCATIONS=South Africa,Johannesburg,Cape Town,Durban,Pretoria
ADZUNA_RESULTS_PER_QUERY=20

# Public ATS boards. Add Greenhouse board slugs or public careers URLs when the employer permits public listing reuse.
GREENHOUSE_BOARDS=
# Lever accepts board slugs or public careers URLs such as https://jobs.lever.co/mamamoney
LEVER_COMPANIES=

# Partner JSON feeds controlled by employers, agencies, or local job boards.
PARTNER_FEED_URLS=

# Optional. If set, admin ingestion endpoints require this bearer token.
ADMIN_TOKEN=

# Optional email delivery for account notifications.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# Automatic ingestion. Keep enabled so users see jobs without entering URLs.
INGEST_ON_START=true
INGEST_INTERVAL_MINUTES=360
